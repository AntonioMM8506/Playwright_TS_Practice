{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Cucumber Scenario (Prompt)",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "cucumber-js",
        "features/**/*.feature",
        "--require-module", "ts-node/register",
        "--require", "features/steps/**/*.ts",
        "--require", "features/support/**/*.ts",
        "--config", "cucumber.config.js",
        "--name", "${input:scenarioName}"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "smartStep": true,
      "cwd": "${workspaceFolder}"
    }
  ],
  "inputs": [
    {
      "id": "scenarioName",
      "type": "promptString",
      "description": "Enter the Scenario name to debug (exactly as in the feature file)"
    }
  ]
}